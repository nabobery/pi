{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"noEmit": true,
		"paths": {
			"@earendil-works/pi-agent-core": ["../agent/src/index.ts"],
			"@earendil-works/pi-ai": ["../ai/src/index.ts"],
			"@earendil-works/pi-ai/oauth": ["../ai/src/oauth.ts"],
			"@earendil-works/pi-coding-agent/runtime": ["../coding-agent/src/runtime.ts"],
			"@earendil-works/pi-tui": ["../tui/src/index.ts"]
		},
		"plugins": [{ "name": "@effect/language-service" }],
		"rootDir": ".",
		"types": ["node", "vite/client"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"test/**/*.ts",
		"test/**/*.tsx",
		"electron.vite.config.ts",
		"vitest.config.ts",
		"playwright.config.ts"
	],
	"exclude": ["node_modules", "dist"]
}
