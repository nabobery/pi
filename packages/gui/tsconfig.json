{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"noEmit": true,
		"rootDir": ".",
		"types": ["node", "vite/client"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"test/**/*.ts",
		"test/**/*.tsx",
		"electron.vite.config.ts",
		"vitest.config.ts",
		"playwright.config.ts"
	],
	"exclude": ["node_modules", "dist"]
}
